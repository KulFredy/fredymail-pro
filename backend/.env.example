# ── Claude (Anthropic) API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For a private channel/group the chat ID starts with -100
TELEGRAM_CHAT_ID=-1001234567890

# ── Scanner Behaviour ────────────────────────────────────────────────────────
# How often to run a full sweep (minutes)
SCAN_INTERVAL_MIN=30
# Minimum confidence score (0-100) required to send an alert
MIN_CONFIDENCE=60
# Timeframes to analyse per coin (comma-separated)
SCAN_TIMEFRAMES=1h,4h
# Optional: override the default 20-coin list (comma-separated, e.g. BTC/USDT,ETH/USDT)
# SCAN_COINS=BTC/USDT,ETH/USDT,SOL/USDT
